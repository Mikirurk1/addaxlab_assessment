PORT=3001
MONGODB_URI=mongodb://example.invalid:27017/example-calendar

# JWT secret used to sign auth tokens
JWT_SECRET=example-jwt-secret

# JWT expiry passed to jsonwebtoken (e.g. "7d")
JWT_EXPIRES_IN=30m

# bcryptjs salt rounds for password hashing
BCRYPT_SALT_ROUNDS=12

# Deterministic avatar filename hashing (email -> filename)
AVATAR_EMAIL_HASH_ALGO=sha512
AVATAR_EMAIL_HASH_SLICE_LENGTH=40


# One-time bootstrap token for creating/updating super-admin credentials via API
SUPER_ADMIN_BOOTSTRAP_TOKEN=example-bootstrap-token

# --- Password reset email (SMTP) ---
# If EMAIL_SMTP_HOST is missing, API will still respond 200,
# but sending will be disabled (it will log the reset link/token instead).
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_SECURE=false
EMAIL_FROM="Addax Assessment <no-reply@example.com>"
# Fallback used only if EMAIL_FROM is empty/missing.
EMAIL_FROM_FALLBACK="no-reply@localhost"

# Email subject shown in "forgot password" messages.
EMAIL_PASSWORD_RESET_SUBJECT="Reset your password"

# Link base used in password reset emails.
# It should point to your client route (e.g. /reset-password).
PASSWORD_RESET_URL_BASE=http://localhost:5173/reset-password

# Token TTL for password reset requests (milliseconds).
PASSWORD_RESET_TOKEN_TTL_MS=1800000
