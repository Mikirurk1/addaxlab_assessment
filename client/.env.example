# API base URL (leave empty in dev to use Vite proxy; set in production to your API origin)
VITE_API_URL=http://example-backend.local:3001

# Public holidays API base URL (Nager.Date API v3)
VITE_NAGER_DATE_API_URL=https://example.invalid/api/v3

# Dev server port (optional, default 5173)
VITE_DEV_PORT=5174

# Proxy target for /api and /ws in dev (optional; defaults to the dev server)
# For Vite dev server proxying. Set this to your backend origin.
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# Super-admin email for admin UI (optional)
# VITE_SUPER_ADMIN_EMAIL=admin@example.invalid
